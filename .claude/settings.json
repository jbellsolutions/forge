{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pytest:*)",
      "Bash(forge:*)",
      "Bash(python:*)",
      "Bash(git:*)",
      "Bash(railway logs:*)",
      "Bash(railway status:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)"
    ]
  },
  "hooks": {
    "PostToolUse": [],
    "Stop": []
  },
  "model": "opus"
}
