{
  "version": "1.0.0",
  "patterns": [
    {"name": "anthropic_key", "regex": "sk-ant-[A-Za-z0-9_-]{20,}", "severity": "high"},
    {"name": "openai_key", "regex": "sk-[A-Za-z0-9]{20,}", "severity": "high"},
    {"name": "tavily_key", "regex": "tvly-[A-Za-z0-9]{20,}", "severity": "high"},
    {"name": "railway_token", "regex": "(?i)railway[_-]?token[\"'=:\\s]+[A-Za-z0-9_-]{16,}", "severity": "high"},
    {"name": "generic_password", "regex": "(?i)(password|passwd)[\"'=:\\s]+[A-Za-z0-9_!@#$%^&*-]{8,}", "severity": "medium"},
    {"name": "email", "regex": "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}", "severity": "low"},
    {"name": "github_token", "regex": "gh[ps]_[A-Za-z0-9]{36}", "severity": "high"}
  ]
}
